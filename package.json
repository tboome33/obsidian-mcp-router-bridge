{
  "name": "obsidian-mcp-router-bridge",
  "version": "0.1.0",
  "description": "Obsidian community plugin that adds /search/smart and /templates/execute REST routes (companion to obsidian-mcp-router).",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "mcp",
    "router",
    "smart-connections",
    "templater",
    "rest-api"
  ],
  "author": "tboome33",
  "license": "Apache-2.0",
  "homepage": "https://github.com/tboome33/obsidian-mcp-router-bridge",
  "repository": {
    "type": "git",
    "url": "https://github.com/tboome33/obsidian-mcp-router-bridge.git"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "obsidian": "^1.4.11",
    "obsidian-local-rest-api": "^2.5.4",
    "tslib": "^2.6.0",
    "typescript": "^5.3.0"
  }
}
