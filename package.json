{
  "name": "obsidian-mcp-router-bridge",
  "version": "0.2.0",
  "description": "Adds /search/smart, /templates/execute, and GET /open/<path> REST routes to the Local REST API plugin. Companion plugin for the multi-vault MCP router. No native binary, no telemetry.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "deploy": "npm run build && node deploy.mjs",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "mcp",
    "router",
    "smart-connections",
    "templater",
    "rest-api"
  ],
  "author": "tboome33",
  "license": "Apache-2.0",
  "homepage": "https://github.com/tboome33/obsidian-mcp-router-bridge",
  "repository": {
    "type": "git",
    "url": "https://github.com/tboome33/obsidian-mcp-router-bridge.git"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.28.0",
    "obsidian": "^1.4.11",
    "tslib": "^2.6.0",
    "typescript": "^5.3.0"
  }
}
